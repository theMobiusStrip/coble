# Copy to .env and fill in. .env is gitignored and loaded automatically by coble.

# OpenAI — for `-m openai:gpt-5.5`
OPENAI_API_KEY=your-openai-key

# Anthropic — for `-m anthropic:claude-sonnet-4-6`
# ANTHROPIC_API_KEY=your-anthropic-key

# Optional: default model when -m is omitted
# COBLE_MODEL=openai:gpt-5.5
