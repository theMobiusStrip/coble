# Project-local config: copy to .env and fill in. Loaded automatically when
# coble runs from this directory; gitignored.
#
# Prefer a one-time global setup instead (works from any directory):
#   coble config set OPENAI_API_KEY sk-...
# Precedence: shell env > ./.env > ~/.coble/env. Check with: coble doctor

# OpenAI — for `-m openai:gpt-5.5`
OPENAI_API_KEY=your-openai-key

# Anthropic — for `-m anthropic:claude-sonnet-4-6`
# ANTHROPIC_API_KEY=your-anthropic-key

# Optional: default model when -m is omitted
# COBLE_MODEL=openai:gpt-5.5
