{
  "name": "coble",
  "version": "0.1.0",
  "description": "A local, provider-agnostic agent CLI — LangGraph.js core, Ink TUI, durable sessions, human-in-the-loop approvals, built-in evals.",
  "type": "module",
  "license": "MIT",
  "author": "Evan Zheng",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theMobiusStrip/coble.git"
  },
  "bugs": {
    "url": "https://github.com/theMobiusStrip/coble/issues"
  },
  "homepage": "https://github.com/theMobiusStrip/coble#readme",
  "keywords": [
    "agent",
    "cli",
    "langgraph",
    "ink",
    "llm",
    "evals"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "coble": "./dist/cli.js"
  },
  "files": [
    "dist",
    "evals",
    "docs",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx src/cli.tsx eval",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "pack:dry": "npm pack --dry-run --cache .tmp/npm-cache",
    "docker:build": "docker build -t coble ."
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.4.1",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.3",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.7",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "ink": "^7.0.5",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "nanoid": "^5.1.11",
    "react": "^19.2.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
